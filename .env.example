# Required: at least one API key
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional fallback (OpenAI-compatible)
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Digest options
DIGEST_HOURS=48
DIGEST_TOP_N=15
DIGEST_LANG=zh

# Cron schedule (server local time)
# Default: run every day at 08:00
DIGEST_CRON=0 8 * * *

# Timezone and startup behavior
TZ=Asia/Shanghai
RUN_ON_START=true
